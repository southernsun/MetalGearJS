# Copy to web/.env (gitignored) and fill in for the in-game bug-report key (B).
# serve.js reads this; the token never reaches the browser.
#
# Create a FINE-GRAINED personal access token at:
#   https://github.com/settings/tokens?type=beta
# scoped to ONLY the repository below, with Repository permissions:
#   - Contents: Read and write   (to host the clip as a release asset)
#   - Issues:   Read and write   (to open the issue)
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults to southernsun/MetalGearJS.
# GITHUB_REPO=southernsun/MetalGearJS
