# Production secret for the bug-report API. Copy to /etc/metalgear/report.env on the server
# (root-only: chown root:root && chmod 600) — NOT in the repo. serve.js reads these from the
# environment; process.env wins over web/.env, so no web/.env is needed in production.
#
# Fine-grained PAT on the repo: Contents (Read and write) + Issues (Read and write).
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults to southernsun/MetalGearJS.
GITHUB_REPO=southernsun/MetalGearJS

# Bind to localhost so only nginx (same host) can reach the API.
HOST=127.0.0.1
PORT=8099
